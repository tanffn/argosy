# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Node / Next.js
node_modules/
.next/
out/
.turbo/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment
.env
.env.*
!.env.example

# Argosy runtime data — NEVER committed
db/
backups/
logs/
# W1.C-v4 plan-synthesis JSONL forensic trail (one .jsonl per synthesis run).
# Already covered by logs/ above; listed explicitly so the location is
# discoverable when grepping .gitignore for "synthesis".
logs/synthesis/
secrets/
uploads/
transcripts/
*.db
*.db-journal
*.db-wal
*.db-shm

# Per-user configs (multi-tenant data — owner-managed, never in shared repo)
configs/*/
!configs/.gitkeep
!configs/example/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Drawio temp
*.bkp

# Claude Code
.claude/

# Git worktrees (isolated feature workspaces)
.worktrees/

# Scratch / handover kits / NVIDIA-internal tooling — never commit.
# Contains codex-tandem-handover/ + zigzag smoke outputs.
tmp/

# Codex tandem kit promoted from tmp/ — still NVIDIA-internal, still
# never committed. The path is fixed (memory references it) but the
# contents stay local.
tools/codex-tandem/

# Agent-scratch artifacts (codex outputs, watch/inspect scripts,
# review notes, identity checks, etc) accumulated from prior sessions.
# Live under per-area .progress/ + .stats/ dirs.
.progress/
argosy/.stats/
argosy/services/.progress/

# Knowledge-graph output (regenerated via /graphify; never committed).
graphify-out/
