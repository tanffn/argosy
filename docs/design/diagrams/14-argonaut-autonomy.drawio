        </mxCell>

        <mxCell id="modes" value="Limited-account mode toggle  (configs/&lt;user&gt;/agent_settings.yaml + dashboard switch)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#4A90E2;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=12;fontStyle=1;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="1400" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="mode_paper" value="paper&#10;&#10;default at Phase 5 startup&#10;every place_order → PaperFill&#10;no broker network call&#10;&#10;[soak default]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="modes">
          <mxGeometry x="20" y="36" width="430" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="mode_live" value="live&#10;&#10;real broker calls via TWS Gateway&#10;ARGOSY_KILL=1 halts immediately&#10;daily-loss-limit auto-suspends&#10;&#10;[after 4-week soak passes]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#74E274;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=10;align=left;verticalAlign=top;fontStyle=1;" vertex="1" parent="modes">
          <mxGeometry x="470" y="36" width="430" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="mode_queue" value="queue_only&#10;&#10;every proposal enters human queue&#10;auto-execute disabled at every tier&#10;regardless of account&#10;&#10;[on-demand override · safe pause]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#E2A674;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="modes">
