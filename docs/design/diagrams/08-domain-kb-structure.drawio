        <mxCell id="callout_yaml" value="---&#10;topic: israeli_capital_gains&#10;jurisdiction: israel&#10;last_verified: 2026-01-15&#10;next_refresh_due: 2026-07-15      # 6 months for stable rules; 1y for brackets&#10;sources:&#10;  - url: https://taxes.gov.il/...&#10;    retrieved: 2026-01-15&#10;    tier: 1                        # source-credibility tier&#10;  - url: https://...&#10;    retrieved: 2026-01-15&#10;    tier: 1&#10;---" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E2A674;strokeWidth=1;fontFamily=Consolas,Courier New,monospace;fontSize=10;align=left;verticalAlign=top;fontColor=#000000;" vertex="1" parent="callout">
