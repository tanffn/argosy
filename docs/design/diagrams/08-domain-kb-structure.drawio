        <mxCell id="rf_yes" value="Yes → write to review queue&#10;NEVER auto-edits&#10;(human approves merge)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6E6;strokeColor=#E27474;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=10;" vertex="1" parent="refresh_frame">
