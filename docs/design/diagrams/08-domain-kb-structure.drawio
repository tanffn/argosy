        <mxCell id="rf_step1" value="1. Scan files for next_refresh_due ≤ today" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#74E274;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=10;" vertex="1" parent="refresh_frame">
