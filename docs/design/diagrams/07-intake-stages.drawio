        <mxCell id="recur_frame" value="Recurring intake cadences  (re-run subset of Stage 3 — short version, not full interview)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#E2A674;strokeWidth=2;dashed=1;fontColor=#000000;fontFamily=Calibri;fontSize=12;fontStyle=1;verticalAlign=top;align=left;" vertex="1" parent="1">
