        <mxCell id="r_monthly" value="Monthly  (1st + reminder if not given by 5th)&#10;&#10;• pay stubs&#10;• bank balance snapshot&#10;• position sync (auto via API where available)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#E2A674;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
