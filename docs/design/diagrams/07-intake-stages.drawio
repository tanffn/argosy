<mxfile host="app.diagrams.net" modified="2026-05-02">
  <diagram id="argosy-intake" name="Intake Stages">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="950">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Argosy — Intake Phase (6 sequential stages)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Calibri;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="600" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="One-shot at setup; re-runs on monthly / quarterly / annual cadences feed back into Stage 3" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Calibri;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="350" y="58" width="800" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="s1" value="Stage 1 — IDENTITY &amp; JURISDICTION" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="240" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="s1_body" value="• Country of tax residence&#10;• Citizenship&#10;• Family status&#10;&#10;Loads relevant&#10;domain_knowledge/tax/&lt;jurisdiction&gt;/&#10;&#10;Instantiates rule set" style="text;html=1;align=left;verticalAlign=top;fontFamily=Calibri;fontSize=10;" vertex="1" parent="s1">
          <mxGeometry x="10" y="32" width="220" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="s2" value="Stage 2 — GOALS &amp; TIMELINE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="320" y="120" width="240" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="s2_body" value="• Retirement target&#10;• Income target&#10;• Near-term spending&#10;• Kids' education&#10;• Charitable plans&#10;&#10;Goal-set with timelines&#10;used by plan-critique" style="text;html=1;align=left;verticalAlign=top;fontFamily=Calibri;fontSize=10;" vertex="1" parent="s2">
          <mxGeometry x="10" y="32" width="220" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="s3" value="Stage 3 — FINANCIAL PICTURE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#E2A674;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="580" y="120" width="240" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="s3_body" value="Priority-ordered:&#10;income → bank →&#10;brokerage → pensions →&#10;real estate →&#10;insurance → tax filings&#10;&#10;Each: doc upload OR&#10;self-report + confidence" style="text;html=1;align=left;verticalAlign=top;fontFamily=Calibri;fontSize=10;" vertex="1" parent="s3">
          <mxGeometry x="10" y="32" width="220" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="s4" value="Stage 4 — BROKERAGE CONNECTIONS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="840" y="120" width="240" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="s4_body" value="• IBKR API key (limited acct)&#10;• Schwab read-only export&#10;  schedule&#10;• Leumi TSV upload&#10;  schedule&#10;&#10;Encrypted in state DB&#10;(Fernet + keychain key)" style="text;html=1;align=left;verticalAlign=top;fontFamily=Calibri;fontSize=10;" vertex="1" parent="s4">
          <mxGeometry x="10" y="32" width="220" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="s5" value="Stage 5 — PLAN IMPORT &amp; CRITIQUE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6E6;strokeColor=#E27474;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1100" y="120" width="240" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="s5_body" value="• (Optional) import plan doc&#10;• plan-critique runs full pass&#10;• RED / YELLOW / GREEN&#10;&#10;Outcomes: keep · accept&#10;edits · ask intake to&#10;draft new plan" style="text;html=1;align=left;verticalAlign=top;fontFamily=Calibri;fontSize=10;" vertex="1" parent="s5">
          <mxGeometry x="10" y="32" width="220" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="s6" value="Stage 6 — OPERATIONAL PREFS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="580" y="370" width="240" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="s6_body" value="• Tier override mode&#10;• Execution mode (paper&#10;  for first N weeks)&#10;• Model defaults&#10;• Alert channels&#10;  (email + opt. Telegram)&#10;• Cadence schedule" style="text;html=1;align=left;verticalAlign=top;fontFamily=Calibri;fontSize=10;" vertex="1" parent="s6">
          <mxGeometry x="10" y="32" width="220" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="s_boot" value="Engine boots → cadences start → weekly summary email begins" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#74E274;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="420" width="440" height="80" as="geometry"/>
        </mxCell>

