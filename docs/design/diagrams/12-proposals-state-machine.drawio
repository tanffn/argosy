        <mxCell id="s_human" value="AWAITING_HUMAN&#10;&#10;in proposals queue&#10;dashboard / email approval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#E2A674;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="120" width="220" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="s_cooling" value="COOLING&#10;&#10;T3 only · 24h hold&#10;auto-pause hooks active" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6E6;strokeColor=#E27474;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=11;fontStyle=1;" vertex="1" parent="1">
