  <diagram id="argosy-novice" name="Argosy in one picture">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="820">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Argosy in one picture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Calibri;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="400" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="A pocket diagram for first-time readers — the formal architecture is in Section 2" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Calibri;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="350" y="58" width="700" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="blk_user" value="You&#10;(the investor)&#10;&#10;Your goals, plan, accounts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#74E274;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="180" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="blk_intake" value="Intake&#10;&#10;A friendly interview that&#10;learns who you are, what&#10;you own, and what you want" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="120" width="200" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="blk_engine" value="Engine&#10;(always-on watcher)&#10;&#10;Polls market, news, prices,&#10;your positions on cheap loops.&#10;Wakes the team only when&#10;something interesting happens." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="340" width="280" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="blk_team" value="Agent fleet&#10;(team of AI specialists)&#10;&#10;Analysts read the situation,&#10;Researchers debate bull vs bear,&#10;Trader drafts the move,&#10;Risk team stress-tests it,&#10;Fund manager signs off." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="340" width="280" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="blk_proposal" value="A proposal&#10;&#10;A concrete trade idea with&#10;the full reasoning trail —&#10;tier-graded by impact (T0..T3)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="120" width="240" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="blk_human" value="You approve&#10;(big trades)&#10;&#10;1-click on the dashboard&#10;or via signed email link.&#10;T3 trades cool off 24h first." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6E6;strokeColor=#E27474;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="300" width="240" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="blk_auto" value="Auto-execute&#10;(small trades, limited account)&#10;&#10;T0 / T1 inside the bounded&#10;Argonaut account run themselves;&#10;kill-switch always available." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#74E274;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="460" width="240" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="blk_exec" value="Broker&#10;(IBKR / Schwab / Leumi)&#10;&#10;Order placed (live) or recorded&#10;as a paper-fill (default)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0E6FF;strokeColor=#B274E2;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=11;" vertex="1" parent="1">
