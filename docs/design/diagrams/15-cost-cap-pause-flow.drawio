<mxfile host="app.diagrams.net" modified="2026-05-02">
  <diagram id="argosy-cost" name="Cost Cap Pause Flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="850">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Argosy — Cost Cap &amp; Pause Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Calibri;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="500" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Monthly Claude spend gate — 80% alert / 100% pause non-routine; ROUTINE_LOOPS exempt to keep dashboard alive" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Calibri;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="350" y="58" width="800" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="trigger" value="Cadence loop is about to invoke an LLM agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="380" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="check_spend" value="Read this month's Claude spend&#10;from agent_reports table" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#E2A674;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="380" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="dec_80" value="Spend ≥ 80% of monthly cap?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#E2A674;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="320" width="260" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="dec_100" value="Spend ≥ 100% of monthly cap?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFE6E6;strokeColor=#E27474;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="460" width="260" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="alert_80" value="Send alert (email + dashboard banner)&#10;&#10;subject: Argosy spend at 80% of monthly cap&#10;ETA to 100% based on rolling 7d burn rate&#10;link to Agent Activity screen for breakdown" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#E2A674;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="500" y="320" width="430" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="dec_routine" value="Is this loop in ROUTINE_LOOPS?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFE6E6;strokeColor=#E27474;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="500" y="460" width="260" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="routine_box" value="ROUTINE_LOOPS&#10;&#10;daily_brief — kept alive (small fixed cost ~$0.20/day, dashboard-critical)&#10;process_cooling — kept alive (drains pending T3 cooling, must run)&#10;&#10;Everything else — minute · hour · weekly · monthly · quarterly · annual · ad-hoc · all decision flows — paused" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="800" y="460" width="640" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="proceed" value="Proceed: invoke agent · cost stamped on agent_reports row&#10;(daily summary surfaces in Agent Activity screen)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#74E274;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="640" width="640" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="pause" value="PAUSE  (skip this LLM invocation)&#10;&#10;dashboard banner: spending paused until next month or override&#10;user can: extend cap (settings) · override one-shot (button) · wait for month rollover" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6E6;strokeColor=#E27474;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="640" width="640" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="e_t_check" style="endArrow=classic;html=1;rounded=1;strokeColor=#4A90E2;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="trigger" target="check_spend"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_check_80" style="endArrow=classic;html=1;rounded=1;strokeColor=#4A90E2;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="check_spend" target="dec_80"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_80_yes" style="endArrow=classic;html=1;rounded=1;strokeColor=#E2A674;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="dec_80" target="alert_80"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_80_yes_l" value="yes — alert fires once" style="text;html=1;align=center;fontFamily=Calibri;fontSize=10;fontStyle=1;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="385" y="355" width="120" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="e_80_no" style="endArrow=classic;html=1;rounded=1;strokeColor=#74E274;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="dec_80" target="proceed">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="40" y="370"/>
              <mxPoint x="40" y="680"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_80_no_l" value="no — proceed" style="text;html=1;align=center;fontFamily=Calibri;fontSize=10;fontStyle=1;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="20" y="500" width="100" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="e_alert_100" style="endArrow=classic;html=1;rounded=1;strokeColor=#E27474;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="alert_80" target="dec_100">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="710" y="450"/>
              <mxPoint x="385" y="450"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_alert_100_l" value="continue check (cap not yet hit)" style="text;html=1;align=center;fontFamily=Calibri;fontSize=10;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="430" y="425" width="220" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="e_100_yes" style="endArrow=classic;html=1;rounded=1;strokeColor=#E27474;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="dec_100" target="dec_routine"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_100_yes_l" value="yes" style="text;html=1;align=center;fontFamily=Calibri;fontSize=10;fontStyle=1;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="385" y="500" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="e_100_no" style="endArrow=classic;html=1;rounded=1;strokeColor=#74E274;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="dec_100" target="proceed">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="40" y="510"/>
              <mxPoint x="40" y="680"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_100_no_l" value="no — proceed" style="text;html=1;align=center;fontFamily=Calibri;fontSize=10;fontStyle=1;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="20" y="600" width="100" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="e_rt_proceed" style="endArrow=classic;html=1;rounded=1;strokeColor=#74E274;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="dec_routine" target="proceed">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="630" y="510"/>
              <mxPoint x="380" y="510"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_rt_proceed_l" value="yes — daily_brief OR process_cooling → keep alive" style="text;html=1;align=center;fontFamily=Calibri;fontSize=10;fontStyle=1;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="350" y="600" width="350" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="e_rt_pause" style="endArrow=classic;html=1;rounded=1;strokeColor=#E27474;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="dec_routine" target="pause"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_rt_pause_l" value="no — pause" style="text;html=1;align=center;fontFamily=Calibri;fontSize=10;fontStyle=1;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="765" y="600" width="100" height="20" as="geometry"/>
