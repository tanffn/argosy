        <mxCell id="proto" value="BrokerAdapter Protocol  (common interface — engine treats all three accounts uniformly)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=2;fontColor=#000000;fontFamily=Calibri;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="1380" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="proto_body" value="get_positions(account_id) -&gt; list[Position]&#10;get_lots(account_id, ticker) -&gt; list[Lot]&#10;place_order(order, paper=True) -&gt; ExecutionResult&#10;cancel_order(order_id) -&gt; CancellationResult&#10;get_open_orders(account_id) -&gt; list[OpenOrder]&#10;&#10;Paper mode universal: every adapter honors paper=True and writes a PaperFill to audit log instead of placing." style="text;html=1;align=left;verticalAlign=top;fontFamily=Consolas,Courier New,monospace;fontSize=10;" vertex="1" parent="proto">
          <mxGeometry x="20" y="36" width="1340" height="80" as="geometry"/>
        </mxCell>

