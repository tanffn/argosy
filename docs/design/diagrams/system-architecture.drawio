<mxfile host="app.diagrams.net" agent="Argosy SDD v0.1" version="24.0.0">
  <diagram name="Argosy System Architecture" id="argosy-arch-v1">
    <mxGraphModel dx="1654" dy="1169" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Argosy — Top-Level System Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="700" height="40" as="geometry" />
        </mxCell>
        <mxCell id="intake" value="INTAKE&#10;&#10;LLM-led interview&#10;Doc ingestion (pay stubs, statements, plan)&#10;Plan critique&#10;Broker config&#10;&#10;One-shot at setup; re-runnable&#10;monthly / quarterly / annual" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=center;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="320" height="220" as="geometry" />
        </mxCell>
        <mxCell id="state" value="PERSISTENT STATE (SQLite + DuckDB)&#10;&#10;user_context · plan · positions · lots&#10;agent_reports · proposals · alerts&#10;audit_log · prices_cache · news_cache&#10;domain_kb_status · cadence_state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="430" y="100" width="380" height="220" as="geometry" />
        </mxCell>
        <mxCell id="ui" value="UI&#10;&#10;FastAPI (:8000) + Next.js (:1337)&#10;shadcn/ui · Recharts · WebSocket&#10;&#10;10 screens: Home · Portfolio · Plan&#10;Proposals · Argonaut · Agent Activity&#10;Audit Log · Domain KB · Intake · Settings&#10;&#10;Email approval channel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="880" y="100" width="320" height="220" as="geometry" />
        </mxCell>
        <mxCell id="engine" value="ENGINE — always-on Python orchestrator&#10;&#10;Cadence loops:&#10;  · Minute (market hours) — order management, vol bands&#10;  · Hour — news delta, macro calendar&#10;  · Daily brief (09:00) — overnight ingest, day setup&#10;  · Weekly review (Sun 18:00) — domain refresh, audit&#10;  · Monthly cycle (1st) — buy plan, plan critique&#10;  · Quarterly · Annual · Ad-hoc&#10;&#10;Each loop: poll cheaply → check triggers → if hit, invoke decision flow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=center;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="560" height="220" as="geometry" />
        </mxCell>
        <mxCell id="decision" value="DECISION AGENT TEAM (TradingAgents pattern)&#10;&#10;Analysts (parallel, structured reports):&#10;  fundamentals · news · technical · sentiment&#10;  macro · plan-critique · concentration · tax · FX&#10;          ↓&#10;Researcher debate (n rounds, facilitated): bull / bear&#10;          ↓&#10;Trader proposal&#10;          ↓&#10;Risk team (n rounds, facilitated): aggressive / neutral / conservative&#10;          ↓&#10;Fund manager: APPROVED PROPOSAL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=center;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="640" y="380" width="560" height="220" as="geometry" />
        </mxCell>
        <mxCell id="exec" value="EXECUTION&#10;&#10;Phase 1 — Main accounts (Schwab, Leumi):&#10;  queue → email → 1-click approve → IBKR (where available)&#10;&#10;Phase 2 — Limited (Argonaut) account at IBKR Pro:&#10;  T0 / T1 auto-execute within tier rules&#10;  T2 / T3 always require human approval&#10;  Cooling-off (T3) · Kill switch · Idempotency UUIDs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=center;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="280" y="660" width="680" height="180" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=2" edge="1" parent="1" source="intake" target="state">
