        <mxCell id="cp_t1" value="T1 — Standard&#10;steps 1-10 with reduced fan-out: 3 most-relevant analysts, 1-round debate, 1 risk perspective. Auto-execute in limited acct." style="text;html=1;align=left;verticalAlign=top;fontFamily=Calibri;fontSize=10;" vertex="1" parent="cond_panel">
