        </mxCell>

        <mxCell id="m2" value="2. fan out to 9 analysts (parallel) — fundamentals · technical · news · sentiment · macro · plan-critique · concentration · tax · FX&#10;     [T1: 3 most relevant only] [T0: skipped — trader-only]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=10;align=left;" vertex="1" parent="1">
