        </mxCell>

        <mxCell id="m4" value="4. researcher debate (n rounds, facilitated) — bull vs bear, with each round responding to prior&#10;     [T1: 1 round]  [T2: 2 rounds]  [T3: 2 rounds + plan-critique sign-off]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90E2;strokeWidth=1.5;fontColor=#000000;fontFamily=Calibri;fontSize=10;align=left;" vertex="1" parent="1">
